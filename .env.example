# Copy to .env on the target server and fill in real values.
# .env is gitignored -- never commit real values.

ES_PASSWORD=<generate-with-elasticsearch-reset-password>
GRAFANA_ADMIN_PASSWORD=<choose-a-strong-password>
REPORTING_SERVER_IP=<this-server-ip>
PROXY_SERVER_IP_1=<primary-safesquid-proxy-ip>
PROXY_SERVER_IP_2=<secondary-safesquid-proxy-ip>
